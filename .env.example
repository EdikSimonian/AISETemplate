# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase — get these from your project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# LiteLLM — API key for your LiteLLM proxy (leave blank if your proxy has no auth)
LITELLM_API_KEY=your-litellm-api-key-here

# Optional: override the default AI model
# LITELLM_MODEL=gpt-4o-mini
