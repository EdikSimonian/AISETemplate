# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase — get these from your project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# DeepInfra — get this from deepinfra.com/dashboard
DEEPINFRA_API_KEY=your-deepinfra-api-key-here

# Optional: override the default AI model
# DEEPINFRA_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
