# Copy this file to .streamlit/secrets.toml for local Streamlit secrets.
# Never commit secrets.toml to version control.
# For production, add these in Streamlit Community Cloud → App Settings → Secrets.

SUPABASE_URL = "https://your-project-id.supabase.co"
SUPABASE_ANON_KEY = "your-anon-key-here"
DEEPINFRA_API_KEY = "your-deepinfra-api-key-here"

# Optional
# DEEPINFRA_MODEL = "meta-llama/Meta-Llama-3.1-8B-Instruct"
